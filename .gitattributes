# Normalize line endings: let git decide on checkout, store LF in the repo.
* text=auto

# Scripts that MUST keep their native endings regardless of platform.
*.sh   text eol=lf
*.ps1  text eol=crlf

# C#/XAML source - LF in repo, native on checkout.
*.cs    text
*.axaml text
*.csproj text
*.slnx  text

# Binary assets - never touch.
*.ico  binary
*.png  binary
*.icns binary
