<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CleanSweep.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="700"
        x:Class="CleanSweep.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="CleanSweep" Width="1060" Height="760"
        MinWidth="880" MinHeight="600"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur, Mica, Blur">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>

        <!-- ============ Shared item templates (implicit by type) ============ -->

        <!-- A single scan item, with the "What is this?" AI flyout -->
        <DataTemplate DataType="vm:CleanItemViewModel" x:DataType="vm:CleanItemViewModel">
            <StackPanel Margin="6,5">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open" Command="{Binding OpenCommand}" IsEnabled="{Binding CanReveal}"/>
                        <MenuItem Header="Reveal in file manager" Command="{Binding RevealCommand}" IsEnabled="{Binding CanReveal}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Path}" FontSize="10" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="icon" VerticalAlignment="Center" Margin="6,0,10,0"
                            Command="{Binding ExplainCommand}" ToolTip.Tip="What is this? (AI explanation)"
                            AutomationProperties.Name="What is this?">
                        <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource IconHelp}"
                              Fill="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                    <TextBlock Grid.Column="3" Text="{Binding SizeText}" VerticalAlignment="Center"
                               FontFamily="Consolas,monospace" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>

                <Border Classes="flyout card" IsVisible="{Binding IsExplanationOpen}" Margin="26,5,0,6" Padding="13,11">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsExplaining}">
                            <ProgressBar IsIndeterminate="True" Width="90" Height="4" VerticalAlignment="Center"/>
                            <TextBlock Text="Asking the AI..." Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel IsVisible="{Binding HasExplanation}" Spacing="6">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" CornerRadius="9" Padding="9,2" VerticalAlignment="Top" Background="{Binding RiskBrush}">
                                    <TextBlock Text="{Binding RiskText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Explanation.Summary}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                            <TextBlock Text="{Binding Explanation.Reason}" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Explanation.Recommendation}" FontStyle="Italic" TextWrapping="Wrap"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Offline answer - add your API key in Settings to enable AI explanations."
                                       IsVisible="{Binding ShowOfflineHint}" Opacity="0.5" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- A category, as a glass card with an expander -->
        <DataTemplate DataType="vm:CategoryViewModel" x:DataType="vm:CategoryViewModel">
            <Border Classes="card" Margin="0,0,0,13" Padding="8,5">
                <Expander Classes="flat" IsExpanded="{Binding IsExpanded}" Background="Transparent" BorderThickness="0"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" MinWidth="560">
                            <CheckBox Grid.Column="0" IsThreeState="True" IsChecked="{Binding AllSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Classes="iconchip" Margin="4,0,0,0" VerticalAlignment="Center">
                                <Path Width="19" Height="19" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="{Binding Category, Converter={StaticResource CategoryIcon}}" Fill="{DynamicResource AccentSolidBrush}"/>
                            </Border>
                            <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="{Binding Summary}" VerticalAlignment="Center" Margin="8,0,12,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,4,0,4"/>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- A duplicate group -->
        <DataTemplate DataType="vm:DuplicateGroupViewModel" x:DataType="vm:DuplicateGroupViewModel">
            <Border Classes="card" Margin="0,0,0,13" Padding="8,5">
                <Expander Classes="flat" IsExpanded="{Binding IsExpanded}" Background="Transparent" BorderThickness="0"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="*,Auto" MinWidth="560">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Header}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Content="Remove other copies" Margin="8,0,12,0" VerticalAlignment="Center"
                                      IsChecked="{Binding IncludeInCleanup, Mode=TwoWay}"/>
                        </Grid>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding Files}" Margin="0,4,0,4"/>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- A duplicate file row -->
        <DataTemplate DataType="vm:DuplicateFileViewModel" x:DataType="vm:DuplicateFileViewModel">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="14,5,8,5">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open" Command="{Binding OpenCommand}" IsEnabled="{Binding CanReveal}"/>
                        <MenuItem Header="Reveal in file manager" Command="{Binding RevealCommand}" IsEnabled="{Binding CanReveal}"/>
                    </ContextMenu>
                </Grid.ContextMenu>
                <RadioButton Grid.Column="0" Content="Keep" GroupName="{Binding GroupId}" VerticalAlignment="Center"
                             IsChecked="{Binding IsKept, Mode=TwoWay}"/>
                <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Path}" FontSize="10" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding ModifiedText}" VerticalAlignment="Center" Margin="8,0,8,0"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="{Binding SizeText}" VerticalAlignment="Center" FontFamily="Consolas,monospace"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
        </DataTemplate>

        <!-- An installed application -->
        <DataTemplate DataType="vm:AppViewModel" x:DataType="vm:AppViewModel">
            <Border Classes="card" Margin="0,0,0,10" Padding="16,13">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding Publisher}"/><Run Text="   "/><Run Text="{Binding Version}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" VerticalAlignment="Center" Margin="8,0,14,0"
                               FontFamily="Consolas,monospace" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Grid.Column="2" Content="Uninstall" Classes="danger" Command="{Binding UninstallCommand}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- A startup item -->
        <DataTemplate DataType="vm:StartupItemViewModel" x:DataType="vm:StartupItemViewModel">
            <Border Classes="card" Margin="0,0,0,10" Padding="16,13">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Command}" FontSize="10" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,14,0">
                        <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.85">
                            <Run Text="{Binding KindLabel}"/><Run Text="  ·  "/><Run Text="{Binding ScopeLabel}"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="2" Content="{Binding ToggleLabel}" Command="{Binding ToggleCommand}"
                            VerticalAlignment="Center" MinWidth="86"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>
        <!-- Frosted "liquid glass" backdrop -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                             TintColor="{DynamicResource AcrylicTintColor}"
                                             TintOpacity="1" MaterialOpacity="0.55"/>
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- Tinted glass sheet over the blurred backdrop - gives the frosted color -->
        <Panel Background="{DynamicResource GlassOverlayBrush}" IsHitTestVisible="False"/>

        <!-- Soft colour pools behind the glass, so translucent panels read as frosted glass -->
        <Canvas IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Canvas.Left="-150" Canvas.Top="-130" Width="560" Height="560">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#603B82F6" Offset="0"/>
                        <GradientStop Color="#003B82F6" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Canvas.Right="-180" Canvas.Bottom="-180" Width="660" Height="660">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5206B6D4" Offset="0"/>
                        <GradientStop Color="#0006B6D4" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Canvas.Right="140" Canvas.Top="-220" Width="500" Height="500">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4238BDF8" Offset="0"/>
                        <GradientStop Color="#0038BDF8" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Grid ColumnDefinitions="236,*">

            <!-- ============ Sidebar ============ -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="14,18,14,14">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="11" Margin="4,0,0,22">
                        <Border Width="36" Height="36" CornerRadius="11" Background="{DynamicResource AccentBrush}">
                            <Path Data="{StaticResource IconSparkle}" Fill="White" Width="19" Height="19" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CleanSweep" Classes="wordmark"/>
                            <TextBlock Text="Disk &amp; memory cleaner" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="4,14,4,0">
                        <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold" LetterSpacing="1"
                                   Opacity="0.65" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ComboBox ItemsSource="{Binding Settings.Themes}" SelectedIndex="{Binding Settings.ThemeIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <ListBox Classes="nav" SelectedIndex="{Binding SelectedSectionIndex, Mode=TwoWay}">
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Classes="navicon" Data="{StaticResource IconSearch}" Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                <TextBlock Text="Smart Scan" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Classes="navicon" Data="{StaticResource IconFolder}" Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                <TextBlock Text="Large Files" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Classes="navicon" Data="{StaticResource IconCopy}" Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                <TextBlock Text="Duplicates" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Classes="navicon" Data="{StaticResource IconApps}" Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                <TextBlock Text="Apps" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Classes="navicon" Data="{StaticResource IconPower}" Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                <TextBlock Text="Startup" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Classes="navicon" Data="{StaticResource IconMemory}" Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                <TextBlock Text="Memory" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Classes="navicon" Data="{StaticResource IconCog}" Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ============ Content ============ -->
            <Grid Grid.Column="1">

                <!-- Smart Scan -->
                <DockPanel Classes="page" Opacity="{Binding IsSmartScanSection, Converter={StaticResource BoolToOpacity}}" IsHitTestVisible="{Binding IsSmartScanSection}" Margin="28,24">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Smart Scan" Classes="h1"/>
                            <TextBlock Text="Find reclaimable space across your system" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="Smart Scan" Classes="accent" FontWeight="SemiBold" Padding="18,9"
                                    Command="{Binding ScanCommand}" IsEnabled="{Binding !IsBusy}"/>
                            <Button Content="Cancel" Command="{Binding CancelCommand}" IsVisible="{Binding IsBusy}"/>
                        </StackPanel>
                    </Grid>

                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                                 IsVisible="{Binding IsBusy}"/>

                    <!-- Reclaimable ring -->
                    <Border DockPanel.Dock="Top" Classes="card" Margin="0,14,0,0" Padding="20,16" IsVisible="{Binding HasResults}">
                        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                            <Grid Grid.Column="0" Width="150" Height="150">
                                <Ellipse Width="150" Height="150" StrokeThickness="11" Stroke="{DynamicResource HairlineBrush}"/>
                                <Path StrokeThickness="11" StrokeLineCap="Round" Stroke="{DynamicResource AccentBrush}"
                                      Data="{Binding SelectedFraction, Converter={StaticResource RingGauge}}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalReclaimableText}" FontSize="21" FontWeight="Bold"
                                               HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="reclaimable" FontSize="11" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center" Spacing="6">
                                <TextBlock Text="Reclaimable space" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="Selected"/>
                                    <Run Text="{Binding SelectedText}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Run Text="of"/>
                                    <Run Text="{Binding TotalReclaimableText}"/>
                                    <Run Text="- tick what you want below, then Clean."/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Classes="card" Padding="16,12" Margin="0,14,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding StatusText}" TextWrapping="Wrap"
                                       VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Button Grid.Column="1" Content="Clean" Classes="accent" FontWeight="Bold"
                                    Padding="22,10" Command="{Binding CleanCommand}" IsEnabled="{Binding HasResults}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Margin="0,14,0,0">
                        <Panel>
                            <ItemsControl ItemsSource="{Binding Categories}"/>
                            <StackPanel IsVisible="{Binding !HasResults}" HorizontalAlignment="Center"
                                        VerticalAlignment="Top" Margin="0,80,0,0" Spacing="14">
                                <Path Data="{StaticResource IconSearch}" Width="56" Height="56" Stretch="Uniform"
                                      HorizontalAlignment="Center" Fill="{DynamicResource TextSecondaryBrush}" Opacity="0.35"/>
                                <TextBlock Text="No scan results yet - click Smart Scan to begin."
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Panel>
                    </ScrollViewer>
                </DockPanel>

                <!-- Large Files -->
                <DockPanel Classes="page" Opacity="{Binding IsLargeFilesSection, Converter={StaticResource BoolToOpacity}}" IsHitTestVisible="{Binding IsLargeFilesSection}" Margin="28,24">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Large Files" Classes="h1"/>
                            <TextBlock Text="Big files worth reviewing (≥ 100 MB) - opt in before deleting" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Clean" Classes="accent" FontWeight="Bold" Padding="20,9"
                                VerticalAlignment="Center" Command="{Binding CleanCommand}" IsEnabled="{Binding HasResults}"/>
                    </Grid>

                    <ScrollViewer Margin="0,14,0,0">
                        <Panel>
                            <ItemsControl ItemsSource="{Binding LargeFilesCategory.Items}" IsVisible="{Binding HasLargeFiles}"/>
                            <StackPanel IsVisible="{Binding !HasLargeFiles}" HorizontalAlignment="Center"
                                        VerticalAlignment="Top" Margin="0,80,0,0" Spacing="14">
                                <Path Data="{StaticResource IconFolder}" Width="56" Height="56" Stretch="Uniform"
                                      HorizontalAlignment="Center" Fill="{DynamicResource TextSecondaryBrush}" Opacity="0.35"/>
                                <TextBlock Text="Run a Smart Scan first to list large files here."
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Panel>
                    </ScrollViewer>
                </DockPanel>

                <!-- Duplicates -->
                <DockPanel Classes="page" Opacity="{Binding IsDuplicatesSection, Converter={StaticResource BoolToOpacity}}" IsHitTestVisible="{Binding IsDuplicatesSection}" Margin="28,24">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Duplicate Files" Classes="h1"/>
                            <TextBlock Text="Identical files found in more than one place" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="Find Duplicates" Classes="accent" FontWeight="SemiBold" Padding="16,8"
                                    Command="{Binding Duplicates.ScanCommand}" IsEnabled="{Binding !Duplicates.IsBusy}"/>
                            <Button Content="Cancel" Command="{Binding Duplicates.CancelCommand}" IsVisible="{Binding Duplicates.IsBusy}"/>
                            <Button Content="Delete selected" Classes="danger"
                                    Command="{Binding Duplicates.DeleteSelectedCommand}" IsEnabled="{Binding Duplicates.HasGroups}"/>
                        </StackPanel>
                    </Grid>

                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                                 IsVisible="{Binding Duplicates.IsBusy}"/>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Duplicates.StatusText}" TextWrapping="Wrap"
                               Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <ScrollViewer Margin="0,14,0,0">
                        <ItemsControl ItemsSource="{Binding Duplicates.Groups}"/>
                    </ScrollViewer>
                </DockPanel>

                <!-- Apps -->
                <DockPanel Classes="page" Opacity="{Binding IsAppsSection, Converter={StaticResource BoolToOpacity}}" IsHitTestVisible="{Binding IsAppsSection}" Margin="28,24">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Applications" Classes="h1"/>
                            <TextBlock Text="Uninstall apps you no longer need" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="List Applications" Classes="accent" FontWeight="SemiBold" Padding="16,8"
                                VerticalAlignment="Center" Command="{Binding Apps.LoadCommand}" IsEnabled="{Binding !Apps.IsBusy}"/>
                    </Grid>

                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                                 IsVisible="{Binding Apps.IsBusy}"/>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Apps.StatusText}" TextWrapping="Wrap"
                               Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <ScrollViewer Margin="0,14,0,0">
                        <ItemsControl ItemsSource="{Binding Apps.Apps}"/>
                    </ScrollViewer>
                </DockPanel>

                <!-- Startup -->
                <DockPanel Classes="page" Opacity="{Binding IsStartupSection, Converter={StaticResource BoolToOpacity}}" IsHitTestVisible="{Binding IsStartupSection}" Margin="28,24">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Startup Items" Classes="h1"/>
                            <TextBlock Text="Control what launches at login - disabling is reversible" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="List Startup Items" Classes="accent" FontWeight="SemiBold" Padding="16,8"
                                VerticalAlignment="Center" Command="{Binding Startup.LoadCommand}" IsEnabled="{Binding !Startup.IsBusy}"/>
                    </Grid>

                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                                 IsVisible="{Binding Startup.IsBusy}"/>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Startup.StatusText}" TextWrapping="Wrap"
                               Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <ScrollViewer Margin="0,14,0,0">
                        <ItemsControl ItemsSource="{Binding Startup.Items}"/>
                    </ScrollViewer>
                </DockPanel>

                <!-- Memory -->
                <DockPanel Classes="page" Opacity="{Binding IsMemorySection, Converter={StaticResource BoolToOpacity}}" IsHitTestVisible="{Binding IsMemorySection}" Margin="28,24">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <TextBlock Text="Memory" Classes="h1"/>
                        <TextBlock Text="Free up RAM by trimming process working sets" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Classes="card" Padding="22" VerticalAlignment="Top">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding MemoryText}" FontWeight="SemiBold" FontSize="15"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding MemoryDetail}" FontSize="12" Margin="0,3,0,10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ProgressBar Grid.Row="2" Grid.Column="0" Height="8" Minimum="0" Maximum="100" Value="{Binding MemoryUsedPercent}"/>
                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Content="Free Up RAM" Classes="accent"
                                    FontWeight="SemiBold" Padding="18,10" VerticalAlignment="Center" Margin="18,0,0,0"
                                    Command="{Binding FreeMemoryCommand}"/>
                        </Grid>
                    </Border>
                </DockPanel>

                <!-- Settings -->
                <DockPanel Classes="page" Opacity="{Binding IsSettingsSection, Converter={StaticResource BoolToOpacity}}" IsHitTestVisible="{Binding IsSettingsSection}" Margin="28,24">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <TextBlock Text="Settings" Classes="h1"/>
                        <TextBlock Text="Configure the AI &quot;What is this?&quot; explainer" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <ScrollViewer>
                        <Border Classes="card" Padding="22" VerticalAlignment="Top" HorizontalAlignment="Left" MaxWidth="640">
                            <StackPanel Spacing="10">
                                <TextBlock Text="AI provider" FontWeight="SemiBold" FontSize="15"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="Use any provider's API key - Anthropic, OpenAI, Gemini, or any OpenAI-compatible endpoint. Without one, CleanSweep uses a built-in offline heuristic. Your key is stored locally on this machine only."/>
                                <ComboBox ItemsSource="{Binding Settings.Providers}" HorizontalAlignment="Stretch"
                                          SelectedIndex="{Binding Settings.SelectedProviderIndex, Mode=TwoWay}"/>

                                <TextBlock Text="{Binding Settings.KeyLabel}" FontWeight="SemiBold" Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding Settings.ApiKey, Mode=TwoWay}" PlaceholderText="paste your API key"
                                         FontFamily="Consolas,monospace"/>

                                <TextBlock Text="Endpoint (base URL)" FontWeight="SemiBold" Margin="0,6,0,0"
                                           IsVisible="{Binding Settings.ShowBaseUrl}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding Settings.BaseUrl, Mode=TwoWay}" IsVisible="{Binding Settings.ShowBaseUrl}"
                                         PlaceholderText="https://your-endpoint/v1" FontFamily="Consolas,monospace"/>

                                <TextBlock Text="Model (optional)" FontWeight="SemiBold" Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding Settings.Model, Mode=TwoWay}" PlaceholderText="{Binding Settings.ModelHint}"/>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <Button Content="Save" Classes="accent" FontWeight="SemiBold" Padding="20,8"
                                            Command="{Binding Settings.SaveCommand}"/>
                                    <Button Content="Clear key" Command="{Binding Settings.ClearKeyCommand}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding Settings.StatusText}" TextWrapping="Wrap" Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock FontSize="10" Opacity="0.5" TextWrapping="Wrap">
                                    <Run Text="Stored at:"/>
                                    <Run Text="{Binding Settings.SettingsPath}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </Grid>
    </Panel>
</Window>
