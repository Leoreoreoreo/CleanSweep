<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CleanSweep.App"
             xmlns:local="using:CleanSweep"
             xmlns:conv="using:CleanSweep.Converters"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <!-- Cohesive emerald/teal accent (overrides FluentTheme's system accent palette) -->
            <Color x:Key="SystemAccentColor">#0E9F6E</Color>
            <Color x:Key="SystemAccentColorDark1">#0C8C61</Color>
            <Color x:Key="SystemAccentColorDark2">#0A7853</Color>
            <Color x:Key="SystemAccentColorDark3">#086344</Color>
            <Color x:Key="SystemAccentColorLight1">#2FB587</Color>
            <Color x:Key="SystemAccentColorLight2">#57C39E</Color>
            <Color x:Key="SystemAccentColorLight3">#80D2B5</Color>

            <LinearGradientBrush x:Key="AccentBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#10B981" Offset="0"/>
                <GradientStop Color="#0D9488" Offset="1"/>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentSolidBrush" Color="#0E9F6E"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#E5554D"/>
            <SolidColorBrush x:Key="DangerBrushHover" Color="#D6453D"/>

            <conv:CategoryIconConverter x:Key="CategoryIcon"/>
            <conv:BoolToOpacityConverter x:Key="BoolToOpacity"/>

            <!-- Vector icons (Material-style single-path geometries) -->
            <StreamGeometry x:Key="IconSearch">M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z</StreamGeometry>
            <StreamGeometry x:Key="IconFolder">M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z</StreamGeometry>
            <StreamGeometry x:Key="IconCopy">M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z</StreamGeometry>
            <StreamGeometry x:Key="IconApps">M3,3H11V11H3V3M13,3H21V11H13V3M3,13H11V21H3V13M13,13H21V21H13V13Z</StreamGeometry>
            <StreamGeometry x:Key="IconPower">M16.56,5.44L15.11,6.89C16.84,7.94 18,9.83 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12C6,9.83 7.16,7.94 8.88,6.88L7.44,5.44C5.36,6.88 4,9.28 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12C20,9.28 18.64,6.88 16.56,5.44M13,3H11V13H13V3Z</StreamGeometry>
            <StreamGeometry x:Key="IconMemory">M17,17H7V7H17M21,11V9H19V7C19,5.89 18.1,5 17,5H15V3H13V5H11V3H9V5H7C5.89,5 5,5.89 5,7V9H3V11H5V13H3V15H5V17A2,2 0 0,0 7,19H9V21H11V19H13V21H15V19H17A2,2 0 0,0 19,17V15H21V13H19V11M15,15H9V9H15V15Z</StreamGeometry>
            <StreamGeometry x:Key="IconCog">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</StreamGeometry>
            <StreamGeometry x:Key="IconHelp">M11,18H13V16H11V18M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,6A4,4 0 0,0 8,10H10A2,2 0 0,1 12,8A2,2 0 0,1 14,10C14,12 11,11.75 11,15H13C13,12.75 16,12.5 16,10A4,4 0 0,0 12,6Z</StreamGeometry>
            <StreamGeometry x:Key="IconClock">M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12.5,7H11V13L15.75,15.85L16.5,14.62L12.5,12.25V7Z</StreamGeometry>
            <StreamGeometry x:Key="IconBox">M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L5,8.09V15.91L12,19.85L19,15.91V8.09L12,4.15Z</StreamGeometry>
            <StreamGeometry x:Key="IconDocument">M13,9V3.5L18.5,9M6,2C4.89,2 4,2.89 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2H6Z</StreamGeometry>
            <StreamGeometry x:Key="IconTrash">M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z</StreamGeometry>
            <StreamGeometry x:Key="IconGlobe">M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,19.93C7.05,19.44 4,16.08 4,12C4,11.38 4.08,10.78 4.21,10.21L9,15V16A2,2 0 0,0 11,18M17.9,17.39C17.64,16.58 16.9,16 16,16H15V13A1,1 0 0,0 14,12H8V10H10A1,1 0 0,0 11,9V7H13A2,2 0 0,0 15,5V4.59C17.93,5.77 20,8.64 20,12C20,14.08 19.2,15.97 17.9,17.39Z</StreamGeometry>
            <StreamGeometry x:Key="IconWrench">M22.7,19L13.6,9.9C14.5,7.6 14,4.9 12.1,3C10.1,1 7.1,0.6 4.7,1.7L9,6L6,9L1.6,4.7C0.4,7.1 0.9,10.1 2.9,12.1C4.8,14 7.5,14.5 9.8,13.6L18.9,22.7C19.3,23.1 19.9,23.1 20.3,22.7L22.6,20.4C23.1,20 23.1,19.3 22.7,19Z</StreamGeometry>
            <StreamGeometry x:Key="IconSparkle">M12,2L14.4,9.6L22,12L14.4,14.4L12,22L9.6,14.4L2,12L9.6,9.6Z</StreamGeometry>

            <ResourceDictionary.ThemeDictionaries>
                <!-- Light "liquid glass" palette -->
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AcrylicTintColor">#EEF1F7</Color>
                    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" Opacity="0.45"/>
                    <SolidColorBrush x:Key="CardBrushHover" Color="#FFFFFF" Opacity="0.62"/>
                    <LinearGradientBrush x:Key="CardBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#E8FFFFFF" Offset="0"/>
                        <GradientStop Color="#5CFFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF" Opacity="0.32"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#000000" Opacity="0.08"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F131B"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#0F131B" Opacity="0.6"/>
                    <SolidColorBrush x:Key="NavSelectedBrush" Color="#0E9F6E" Opacity="0.14"/>
                    <SolidColorBrush x:Key="NavHoverBrush" Color="#000000" Opacity="0.05"/>
                    <SolidColorBrush x:Key="AccentTintBrush" Color="#0E9F6E" Opacity="0.13"/>
                    <!-- Lower alpha so the acrylic desktop-blur shows through as real glass depth -->
                    <LinearGradientBrush x:Key="GlassOverlayBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#55CDEBE2" Offset="0"/>
                        <GradientStop Color="#52C9E6EC" Offset="0.55"/>
                        <GradientStop Color="#55D3ECDE" Offset="1"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
                <!-- Dark "liquid glass" palette -->
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="AcrylicTintColor">#15171C</Color>
                    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" Opacity="0.09"/>
                    <SolidColorBrush x:Key="CardBrushHover" Color="#FFFFFF" Opacity="0.14"/>
                    <LinearGradientBrush x:Key="CardBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#38FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF" Opacity="0.05"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#FFFFFF" Opacity="0.10"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F4F8"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#F2F4F8" Opacity="0.62"/>
                    <SolidColorBrush x:Key="NavSelectedBrush" Color="#2FB587" Opacity="0.22"/>
                    <SolidColorBrush x:Key="NavHoverBrush" Color="#FFFFFF" Opacity="0.06"/>
                    <SolidColorBrush x:Key="AccentTintBrush" Color="#2FB587" Opacity="0.18"/>
                    <!-- Lower alpha so the acrylic desktop-blur shows through as real glass depth -->
                    <LinearGradientBrush x:Key="GlassOverlayBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#70102A2C" Offset="0"/>
                        <GradientStop Color="#6C0F2630" Offset="0.55"/>
                        <GradientStop Color="#7011302A" Offset="1"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>

        <!-- Translucent rounded card surface -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BoxShadow" Value="0 12 36 0 #33000000"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.18"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.card:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBrushHover}"/>
            <Setter Property="RenderTransform" Value="translateY(-3px)"/>
        </Style>

        <!-- Section pages cross-fade when switching the sidebar -->
        <Style Selector="DockPanel.page">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Accent buttons: round the FluentTheme accent button -->
        <Style Selector="Button.accent">
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <!-- Destructive buttons -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerBrushHover}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Round icon button (the "What is this?" affordance), content centered -->
        <Style Selector="Button.icon">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.icon:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.12)"/>
        </Style>

        <!-- Icons inside nav / category rows / buttons -->
        <Style Selector="Path.navicon">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Sidebar nav list -->
        <Style Selector="ListBox.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavHoverBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavSelectedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentSolidBrush}"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="CornerRadius" Value="9"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected">
            <Setter Property="Foreground" Value="{StaticResource AccentSolidBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Typography -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="-0.6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.wordmark">
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="-0.5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- Category icon chip -->
        <Style Selector="Border.iconchip">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
        </Style>

        <!-- Expander: flatten chrome so it reads as part of the glass -->
        <Style Selector="Expander.flat /template/ Border#ExpanderHeader">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Fade-in for the AI explanation flyout -->
        <Style Selector="Border.flyout">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
    </Application.Styles>
</Application>
